# ── OpenClaw ───────────────────────────────────────────────────────────────────
# Gateway authentication token (generate a random secret; e.g. `openssl rand -hex 32`)
OPENCLAW_GATEWAY_TOKEN=

# Host directories for OpenClaw data (create these before first run)
OPENCLAW_CONFIG_DIR=~/.openclaw
OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace

# LLM session credentials (set whichever you use)
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=

# Optional: override gateway port (default: 18789)
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_BRIDGE_PORT=18790

# Host interface the gateway listens on (default: 127.0.0.1 — localhost only).
# Set to 0.0.0.0 to expose to the LAN / tailnet.
# OPENCLAW_GATEWAY_HOST=127.0.0.1

# ── ClawStrike ─────────────────────────────────────────────────────────────────
# Hugging Face token (read-only scope is sufficient)
#
# Setup steps:
# 1. Register at https://huggingface.co
# 2. Accept Meta's license for your chosen model:
#    - English-only (22M, ~350 MB): https://huggingface.co/meta-llama/Llama-Prompt-Guard-2-22M
#    - Multilingual (86M, ~1.7 GB):  https://huggingface.co/meta-llama/Llama-Prompt-Guard-2-86M
# 3. Generate a read-only token: https://huggingface.co/settings/tokens
HF_TOKEN=hf_...
